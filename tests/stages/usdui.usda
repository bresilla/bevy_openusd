#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Y"
    metersPerUnit = 1.0
    doc = "UsdUI: ui:displayName surfaces friendly labels in the tree."
)

def Xform "World" (
    prepend apiSchemas = ["UsdUISceneGraphPrimAPI"]
)
{
    token ui:displayName = "Top of the world"

    def Xform "robot_v3_baseLink_geom_0" (
        prepend apiSchemas = ["UsdUISceneGraphPrimAPI"]
    )
    {
        token ui:displayName = "Main Body"
        token ui:displayGroup = "robot"

        def Cube "Box"
        {
            double size = 0.5
            double3 xformOp:translate = (0, 0.25, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }
    }

    # A sibling without ui:displayName — its tree row should fall back
    # to the leaf name "Plain".
    def Cube "Plain"
    {
        double size = 0.3
        double3 xformOp:translate = (1.0, 0.15, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}
