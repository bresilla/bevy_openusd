#usda 1.0
(
    defaultPrim = "Robot"
    upAxis = "Y"
    metersPerUnit = 1.0
    kilogramsPerUnit = 1.0
    doc = "Phase 4 fixture: 4-link chain with PhysicsArticulationRootAPI on the base. Three revolute joints between four bodies."
)

def Xform "Robot" (
    prepend apiSchemas = ["PhysicsArticulationRootAPI"]
)
{
    def PhysicsScene "PhysicsScene"
    {
        vector3f physics:gravityDirection = (0, -1, 0)
        float physics:gravityMagnitude = 9.81
    }

    def Cube "Link0" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI", "PhysicsCollisionAPI"]
    )
    {
        double size = 0.4
        float physics:mass = 5.0
        bool physics:kinematicEnabled = 1
        double3 xformOp:translate = (0, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Cube "Link1" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI", "PhysicsCollisionAPI"]
    )
    {
        double size = 0.3
        float physics:mass = 1.0
        double3 xformOp:translate = (0.5, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Cube "Link2" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI", "PhysicsCollisionAPI"]
    )
    {
        double size = 0.3
        float physics:mass = 1.0
        double3 xformOp:translate = (1.0, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Cube "Link3" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI", "PhysicsCollisionAPI"]
    )
    {
        double size = 0.2
        float physics:mass = 0.5
        double3 xformOp:translate = (1.5, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Scope "Joints"
    {
        def PhysicsRevoluteJoint "J01"
        {
            rel physics:body0 = </Robot/Link0>
            rel physics:body1 = </Robot/Link1>
            point3f physics:localPos0 = (0.2, 0, 0)
            point3f physics:localPos1 = (-0.15, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
            uniform token physics:axis = "Z"
            float physics:lowerLimit = -90
            float physics:upperLimit = 90
        }

        def PhysicsRevoluteJoint "J12"
        {
            rel physics:body0 = </Robot/Link1>
            rel physics:body1 = </Robot/Link2>
            point3f physics:localPos0 = (0.15, 0, 0)
            point3f physics:localPos1 = (-0.15, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
            uniform token physics:axis = "Z"
            float physics:lowerLimit = -135
            float physics:upperLimit = 135
        }

        def PhysicsRevoluteJoint "J23"
        {
            rel physics:body0 = </Robot/Link2>
            rel physics:body1 = </Robot/Link3>
            point3f physics:localPos0 = (0.15, 0, 0)
            point3f physics:localPos1 = (-0.1, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
            uniform token physics:axis = "Y"
            float physics:lowerLimit = -45
            float physics:upperLimit = 45
        }
    }
}
