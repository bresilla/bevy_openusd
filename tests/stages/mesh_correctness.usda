#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Y"
    metersPerUnit = 1.0
    doc = "M20 fixture: doubleSided, orientation, and extent coverage on UsdGeomMesh."
)

def Xform "World"
{
    def Scope "Materials"
    {
        def Material "Red"
        {
            token outputs:surface.connect = </World/Materials/Red/Surface.outputs:surface>
            def Shader "Surface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.9, 0.1, 0.1)
                float inputs:roughness = 0.5
                token outputs:surface
            }
        }
    }

    # Single-sided quad — USD default, StandardMaterial should stay
    # single-sided with back-face culling.
    def Mesh "SingleSided" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        int[] faceVertexCounts = [4]
        int[] faceVertexIndices = [0, 1, 2, 3]
        point3f[] points = [(-0.5, 0, -0.5), (0.5, 0, -0.5), (0.5, 0, 0.5), (-0.5, 0, 0.5)]
        float3[] extent = [(-0.5, 0, -0.5), (0.5, 0, 0.5)]
        rel material:binding = </World/Materials/Red>
    }

    # Explicitly double-sided quad — same binding, but loader must
    # emit a DIFFERENT StandardMaterial handle with double_sided = true.
    def Mesh "DoubleSided" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        int[] faceVertexCounts = [4]
        int[] faceVertexIndices = [0, 1, 2, 3]
        point3f[] points = [(-0.5, 0, -0.5), (0.5, 0, -0.5), (0.5, 0, 0.5), (-0.5, 0, 0.5)]
        uniform bool doubleSided = true
        float3[] extent = [(-0.5, 0, -0.5), (0.5, 0, 0.5)]
        rel material:binding = </World/Materials/Red>
        double3 xformOp:translate = (2, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    # Left-handed triangle — loader should flip its winding so the
    # triangle remains front-facing under Bevy's default back-face cull.
    def Mesh "LeftHanded"
    {
        int[] faceVertexCounts = [3]
        int[] faceVertexIndices = [0, 1, 2]
        point3f[] points = [(0, 0, 0), (1, 0, 0), (0, 1, 0)]
        float3[] extent = [(0, 0, 0), (1, 1, 0)]
        uniform token orientation = "leftHanded"
        double3 xformOp:translate = (-2, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}
