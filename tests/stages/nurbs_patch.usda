#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Y"
    metersPerUnit = 1.0
    doc = "NurbsPatch: a 4×4 cubic control net forming a smooth arched surface."
)

def Xform "World"
{
    # 4×4 cubic NURBS patch. End-clamped knots in U + V (degree=3,
    # numCps=4 → numKnots=8 with first/last 4 repeated).
    # Control net is laid out row-major: P[0,0..3], P[1,0..3], …
    # The middle ring of CVs is lifted up in Y to form an arch.
    def NurbsPatch "Arch"
    {
        int uVertexCount = 4
        int vVertexCount = 4
        int uOrder = 4
        int vOrder = 4
        double[] uKnots = [0, 0, 0, 0, 1, 1, 1, 1]
        double[] vKnots = [0, 0, 0, 0, 1, 1, 1, 1]
        double2 uRange = (0, 1)
        double2 vRange = (0, 1)
        point3f[] points = [
            (-1.5,  0.0, -1.5), (-0.5,  0.0, -1.5), (0.5,  0.0, -1.5), (1.5,  0.0, -1.5),
            (-1.5,  1.5, -0.5), (-0.5,  2.5, -0.5), (0.5,  2.5, -0.5), (1.5,  1.5, -0.5),
            (-1.5,  1.5,  0.5), (-0.5,  2.5,  0.5), (0.5,  2.5,  0.5), (1.5,  1.5,  0.5),
            (-1.5,  0.0,  1.5), (-0.5,  0.0,  1.5), (0.5,  0.0,  1.5), (1.5,  0.0,  1.5)
        ]
        color3f[] primvars:displayColor = [(0.45, 0.65, 0.95)]
        double3 xformOp:translate = (0, 0.1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}
