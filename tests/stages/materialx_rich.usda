#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Y"
    metersPerUnit = 1.0
    doc = "MaterialX-rich: standard_surface fed by ND_image, ND_normalmap, and ND_multiply nodes."
)

def Xform "World"
{
    def Scope "Materials"
    {
        # standard_surface whose `base_color` connects through a chain:
        # standard_surface.base_color
        #   ← ND_multiply_color3.out
        #       ← ND_image_color3.out (in1: actual texture)
        #       ← (in2: scalar tint constant)
        # standard_surface.normal connects through ND_normalmap → ND_image_vector3
        # standard_surface.metalness reads from a ND_constant_float node.
        def Material "Rich"
        {
            token outputs:mtlx:surface.connect = </World/Materials/Rich/Surface.outputs:out>

            def Shader "Surface"
            {
                uniform token info:id = "ND_standard_surface_surfaceshader"
                color3f inputs:base_color.connect = </World/Materials/Rich/TintMul.outputs:out>
                float inputs:metalness.connect = </World/Materials/Rich/MetalConst.outputs:out>
                vector3f inputs:normal.connect = </World/Materials/Rich/Norm.outputs:out>
                token outputs:out
            }

            def Shader "TintMul"
            {
                uniform token info:id = "ND_multiply_color3"
                color3f inputs:in1.connect = </World/Materials/Rich/Diffuse.outputs:out>
                color3f inputs:in2 = (1.2, 1.0, 0.9)
                token outputs:out
            }

            def Shader "Diffuse"
            {
                uniform token info:id = "ND_image_color3"
                asset inputs:file = @textures/diffuse.png@
                token outputs:out
            }

            def Shader "MetalConst"
            {
                uniform token info:id = "ND_constant_float"
                float inputs:value = 0.85
                token outputs:out
            }

            def Shader "Norm"
            {
                uniform token info:id = "ND_normalmap"
                vector3f inputs:in.connect = </World/Materials/Rich/NormTex.outputs:out>
                token outputs:out
            }

            def Shader "NormTex"
            {
                uniform token info:id = "ND_image_vector3"
                asset inputs:file = @textures/normal.png@
                token outputs:out
            }
        }
    }
}
