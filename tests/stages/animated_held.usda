#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Y"
    metersPerUnit = 1.0
    startTimeCode = 0
    endTimeCode = 48
    timeCodesPerSecond = 24
    doc = "M23 fixture: rotateY time samples — Linear vs Held. Each Held sample value should stay active until the next timeCode, no blending."
)

def Xform "World"
{
    def Cube "LinearSpinner"
    {
        double size = 0.5
        float xformOp:rotateY = 0
        float xformOp:rotateY.timeSamples = {
            0: 0,
            24: 90,
            48: 180,
        }
        uniform token[] xformOpOrder = ["xformOp:rotateY"]
    }

    def Cube "HeldSpinner"
    {
        double size = 0.5
        float xformOp:rotateY = 0 (
            interpolation = "held"
        )
        float xformOp:rotateY.timeSamples = {
            0: 0,
            24: 90,
            48: 180,
        }
        uniform token[] xformOpOrder = ["xformOp:rotateY"]
    }
}
