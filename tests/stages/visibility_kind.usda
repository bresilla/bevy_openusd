#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Y"
    metersPerUnit = 1.0
    doc = "M22 fixture: UsdGeomImageable.visibility + UsdModelAPI.kind coverage."
)

def Xform "World" (
    kind = "assembly"
)
{
    def Xform "Robot" (
        kind = "component"
    )
    {
        def Cube "Body"
        {
            double size = 1.0
        }
    }

    def Cube "Visible"
    {
        double size = 0.5
        double3 xformOp:translate = (2, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Cube "Hidden"
    {
        double size = 0.5
        uniform token visibility = "invisible"
        double3 xformOp:translate = (-2, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Xform "HiddenParent"
    {
        uniform token visibility = "invisible"
        double3 xformOp:translate = (0, 2, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        def Cube "InheritsHidden"
        {
            double size = 0.5
        }
    }
}
