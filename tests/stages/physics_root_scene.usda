#usda 1.0
(
    defaultPrim = "Robot"
    upAxis = "Z"
    metersPerUnit = 1.0
    kilogramsPerUnit = 1.0
    doc = "Isaac Sim convention: defaultPrim is the robot subtree, but PhysicsScene and PhysicsCollisionGroup live as root-level peers. Pre-fix the loader silently dropped them."
)

# Root-level peers of defaultPrim: physics scene + collision group.
def PhysicsScene "physicsScene"
{
    vector3f physics:gravityDirection = (0, 0, -1)
    float physics:gravityMagnitude = 9.81
}

def PhysicsCollisionGroup "colliders"
{
}

# defaultPrim subtree.
def Xform "Robot"
{
    def Cube "Body" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsCollisionAPI"]
    )
    {
        double size = 0.5
    }
}
