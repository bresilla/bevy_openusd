#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Y"
    metersPerUnit = 1.0
    kilogramsPerUnit = 1.0
    doc = "Phase 4 fixture: generic joint with multi-apply LimitAPI + DriveAPI; spherical cone limits; distance joint min/max."
)

def Xform "World"
{
    def PhysicsScene "PhysicsScene"
    {
    }

    def Cube "A" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsCollisionAPI"]
    )
    {
        double size = 0.3
        bool physics:kinematicEnabled = 1
    }

    def Cube "B" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsCollisionAPI"]
    )
    {
        double size = 0.3
        double3 xformOp:translate = (1, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Cube "C" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsCollisionAPI"]
    )
    {
        double size = 0.3
        double3 xformOp:translate = (2, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    # Generic joint with multi-apply LimitAPI:transX (locked: low>high)
    # and LimitAPI:rotZ (limited -30°/30°). Plus a DriveAPI:rotZ with
    # target_velocity and stiffness/damping.
    def PhysicsJoint "GenericAB" (
        prepend apiSchemas = [
            "PhysicsLimitAPI:transX",
            "PhysicsLimitAPI:rotZ",
            "PhysicsDriveAPI:rotZ",
        ]
    )
    {
        rel physics:body0 = </World/A>
        rel physics:body1 = </World/B>
        point3f physics:localPos0 = (0.15, 0, 0)
        point3f physics:localPos1 = (-0.15, 0, 0)
        quatf physics:localRot0 = (1, 0, 0, 0)
        quatf physics:localRot1 = (1, 0, 0, 0)

        # transX locked (low > high)
        float limit:transX:physics:low = 1
        float limit:transX:physics:high = 0
        # rotZ limited -30°/30°
        float limit:rotZ:physics:low = -30
        float limit:rotZ:physics:high = 30

        # Drive on rotZ: angular target velocity 90 deg/s, stiffness +
        # damping in deg-flavoured units (USD authors stiffness as
        # N·m/deg; the projection flips it to N·m/rad).
        uniform token drive:rotZ:physics:type = "force"
        float drive:rotZ:physics:targetVelocity = 90
        float drive:rotZ:physics:stiffness = 100
        float drive:rotZ:physics:damping = 10
        float drive:rotZ:physics:maxForce = 50
    }

    # Spherical joint with cone limits.
    def PhysicsSphericalJoint "Ball" {
        rel physics:body0 = </World/B>
        rel physics:body1 = </World/C>
        point3f physics:localPos0 = (0.15, 0, 0)
        point3f physics:localPos1 = (-0.15, 0, 0)
        quatf physics:localRot0 = (1, 0, 0, 0)
        quatf physics:localRot1 = (1, 0, 0, 0)
        uniform token physics:axis = "X"
        float physics:coneAngle0Limit = 45
        float physics:coneAngle1Limit = 30
    }

    # Distance joint with min/max distance.
    def PhysicsDistanceJoint "Tether" {
        rel physics:body0 = </World/A>
        rel physics:body1 = </World/C>
        point3f physics:localPos0 = (0, 0, 0)
        point3f physics:localPos1 = (0, 0, 0)
        quatf physics:localRot0 = (1, 0, 0, 0)
        quatf physics:localRot1 = (1, 0, 0, 0)
        float physics:minDistance = 0.5
        float physics:maxDistance = 1.5
    }
}
