#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Y"
    metersPerUnit = 1.0
    doc = "UsdGeom primitive coverage for M2 tests. One of each shape + a triangle Mesh."
)

def Xform "World"
{
    def Cube "Box"
    {
        double size = 0.5
        double3 xformOp:translate = (-1.5, 0.25, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Sphere "Ball"
    {
        double radius = 0.3
        double3 xformOp:translate = (-0.5, 0.3, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Cylinder "Pipe"
    {
        double radius = 0.2
        double height = 0.6
        uniform token axis = "Y"
        double3 xformOp:translate = (0.5, 0.3, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Capsule "Cap"
    {
        double radius = 0.18
        double height = 0.4
        uniform token axis = "Y"
        double3 xformOp:translate = (1.5, 0.3, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Mesh "Tri"
    {
        point3f[] points = [(0, 0, 0), (1, 0, 0), (0.5, 0.8, 0)]
        int[] faceVertexCounts = [3]
        int[] faceVertexIndices = [0, 1, 2]
        normal3f[] normals = [(0, 0, 1), (0, 0, 1), (0, 0, 1)]
        double3 xformOp:translate = (-0.5, 0, 1.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}
