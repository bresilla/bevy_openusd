#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Y"
    metersPerUnit = 1.0
    doc = "Cubic Hermite curves: per-CV tangents shape the in/out flow at each anchor."
)

def Xform "World"
{
    # Three CVs: a left anchor, a peak, a right anchor.
    # Tangents are large at the peak so the curve bends sharply there.
    def HermiteCurves "Bend"
    {
        int[] curveVertexCounts = [3]
        point3f[] points = [
            (-1.5, 0.0, 0.0),
            ( 0.0, 1.5, 0.0),
            ( 1.5, 0.0, 0.0)
        ]
        vector3f[] tangents = [
            ( 1.0,  2.0, 0.0),
            ( 2.0,  0.0, 0.0),
            ( 1.0, -2.0, 0.0)
        ]
        float[] widths = [0.05]
        color3f[] primvars:displayColor = [(0.95, 0.65, 0.1)]
        double3 xformOp:translate = (0, 0.4, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    # A second curve where opposing tangents create an S-curve.
    def HermiteCurves "SCurve"
    {
        int[] curveVertexCounts = [4]
        point3f[] points = [
            (-1.5, 0.0,  1.0),
            (-0.5, 0.0,  1.0),
            ( 0.5, 0.0,  1.0),
            ( 1.5, 0.0,  1.0)
        ]
        vector3f[] tangents = [
            ( 0.0,  1.5, 0.0),
            ( 1.0, -1.5, 0.0),
            ( 1.0,  1.5, 0.0),
            ( 0.0, -1.5, 0.0)
        ]
        float[] widths = [0.04]
        color3f[] primvars:displayColor = [(0.2, 0.85, 0.45)]
    }
}
